:80 {
	# Chat proxy — rewrites the PHP path the JS calls to the backend API
	handle /devel/api/chat.php {
		rewrite * /api/chat
		reverse_proxy api:5000 {
			header_up X-Api-Key abc123
		}
	}

	# Health check proxy
	handle /devel/api/health.php {
		rewrite * /api/chat/health
		reverse_proxy api:5000 {
			header_up X-Api-Key abc123
		}
	}

	# Static frontend at /devel/
	handle /devel/* {
		uri strip_prefix /devel
		root * /srv/frontend
		file_server
	}

	# Redirect bare /devel to /devel/
	handle /devel {
		redir /devel/ permanent
	}

	handle / {
		redir /devel/ permanent
	}
}
